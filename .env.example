# Copy to .env and fill in your real values

# Supabase project — find these at https://app.supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...
# Anon key for the dashboard if you wire it up directly to Supabase
SUPABASE_ANON_KEY=eyJhbGciOi...

# Set to true to run Playwright in headed mode (debugging)
PLAYWRIGHT_HEADLESS=true
